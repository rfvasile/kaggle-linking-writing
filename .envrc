# Host venv is for LSP only; code runs in Docker.
export VIRTUAL_ENV="$PWD/.venv"
export PATH="$PWD/.venv/bin:$PATH"

source_env_if_exists .envrc.local

if [ -x ./sync-lsp-venv.sh ] && [ -n "$(./sync-lsp-venv.sh check 2>&1)" ]; then
    echo "[lsp] ./.venv is out of sync with the Kaggle container (image changed on a pull)."
    echo "[lsp] Fix: run  ./sync-lsp-venv.sh  to refresh the mirror, then restart your editor's LSP."
fi
